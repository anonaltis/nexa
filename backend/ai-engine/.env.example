# AI Engine Environment Variables Template
# Copy this file to .env and fill in the actual values

# The port the AI engine server will run on
PORT=5000

# URL for the Python AI services (FastAPI/Reasoning Engine)
PYTHON_AI_URL=http://localhost:8000

# MongoDB connection string
MONGODB_URL=mongodb://localhost:27017/nexa_db

# Secret key for JWT or session management (Add a secure random string)
SECRET_KEY=add_your_secret_key_here

# Google Gemini API Key (Required for AI features)
# Get one from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=add_your_gemini_api_key_here

# Intelligent Demo Mode
# Set to "true" to enable mocked responses if API quota is exhausted
DEMO_MODE=true
